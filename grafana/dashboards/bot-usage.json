{
  "title": "Bot Usage Analytics",
  "uid": "bot-usage",
  "tags": ["food-discovery", "bot"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Total Commands",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": "PostgreSQL",
      "targets": [{"format": "table", "rawSql": "SELECT COUNT(*) AS value FROM bot_usage_log", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "Unique Users",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": "PostgreSQL",
      "targets": [{"format": "table", "rawSql": "SELECT COUNT(DISTINCT user_id) AS value FROM bot_usage_log", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "Commands Today",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": "PostgreSQL",
      "targets": [{"format": "table", "rawSql": "SELECT COUNT(*) AS value FROM bot_usage_log WHERE created_at >= CURRENT_DATE", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "Avg Response Time (ms)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": "PostgreSQL",
      "targets": [{"format": "table", "rawSql": "SELECT ROUND(AVG(response_time_ms)) AS value FROM bot_usage_log WHERE response_time_ms IS NOT NULL", "refId": "A"}]
    },
    {
      "id": 5,
      "title": "Commands per Day (Last 30 Days)",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": "PostgreSQL",
      "targets": [{"format": "table", "rawSql": "SELECT DATE(created_at)::text AS day, COUNT(*) AS count FROM bot_usage_log WHERE created_at > NOW() - INTERVAL '30 days' GROUP BY 1 ORDER BY 1", "refId": "A"}]
    },
    {
      "id": 6,
      "title": "Top Commands",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": "PostgreSQL",
      "targets": [{"format": "table", "rawSql": "SELECT command, COUNT(*) AS count FROM bot_usage_log GROUP BY command ORDER BY count DESC LIMIT 10", "refId": "A"}]
    },
    {
      "id": 7,
      "title": "Recent Activity",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "datasource": "PostgreSQL",
      "targets": [{"format": "table", "rawSql": "SELECT command, username, parameters, response_time_ms, created_at FROM bot_usage_log ORDER BY created_at DESC LIMIT 50", "refId": "A"}]
    }
  ]
}
