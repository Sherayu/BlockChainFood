                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response has required fields\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(data).to.have.property('frequency');",
                  "    pm.expect(data).to.have.property('categories');",
                  "    pm.expect(data).to.have.property('regions');",
                  "    pm.expect(data).to.have.property('active');",
                  "    pm.expect(data).to.have.property('id');",
                  "});",
                  "pm.test(\"Default values are correct\", function () {",
                  "    const data = pm.response.json();",
