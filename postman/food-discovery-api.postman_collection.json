    {
      "name": "Trending Foods",
      "item": [
        {
          "name": "GET - All Trending Foods",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Returns food array\", function () {",
                  "    const data = pm.response.json();",
                  "    pm.expect(Array.isArray(data)).to.be.true;",
                  "    if (data.length > 0) {",
                  "        pm.expect(data[0]).to.have.property('name');",
                  "        pm.expect(data[0]).to.have.property('popularity_score');",
                  "        pm.expect(data[0]).to.have.property('category');",
                  "        pm.expect(data[0]).to.have.property('region');",
                  "        pm.expect(data[0]).to.have.property('id');",
                  "        pm.environment.set(\"food_id\", data[0].id);",
                  "    }",
